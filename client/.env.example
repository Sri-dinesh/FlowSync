# Database Configuration (Supabase)
# Get these from your Supabase project settings
# DATABASE_URL should use pooling connection for serverless environments
# DIRECT_URL should use direct connection for migrations
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/database"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# FastAPI Backend URLs
# For development: ws://localhost:8000 and http://localhost:8000
# For production: Use secure URLs (wss:// and https://)
NEXT_PUBLIC_FASTAPI_WS_URL="wss://api.example.com"
NEXT_PUBLIC_FASTAPI_HTTP_URL="https://api.example.com"
